{
  "name": "acme-cms",
  "version": "1.0.0",
  "description": "Acme Co. static content CMS — full-stack JavaScript MVP",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "start": "node src/server/index.js",
    "dev": "npm run build && concurrently \"vite build --watch\" \"nodemon src/server/index.js\"",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.21.2",
    "marked": "^15.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
